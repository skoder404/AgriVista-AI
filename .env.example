# Copy this file to .env and fill in your values.
# All paths below are relative to the api/ folder unless you use an absolute path.

# --- Next.js / Genkit (frontend) ---
GOOGLE_GENAI_API_KEY=your_google_ai_api_key_here

# --- Flask breed classifier API (optional overrides) ---
# Defaults work when model files live in api/:
#   api/best_densenet_breed_classifier.pth
#   api/classifier/indian_breed_classifier/
# MODEL_PATH=best_densenet_breed_classifier.pth
# CLASS_DIR=classifier/indian_breed_classifier
# PORT=5000
# FLASK_DEBUG=false
